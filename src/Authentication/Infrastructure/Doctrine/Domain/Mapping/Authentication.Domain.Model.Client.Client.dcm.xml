<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                          https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="Authentication\Domain\Model\Client\Client" table="client" repository-class="AuthMicroservice\Authentication\Infrastructure\Doctrine\Domain\Model\Client\ClientDoctrineRepository">

        <id name="id" column="id" type="uuid">
            <generator strategy="NONE"/>
        </id>

        <field name="name" column="name" type="string"/>
        <field name="clientSecret" column="client_secret" type="string"/>
        <field name="redirectUrl" column="redirect_url" type="string"/>
        <field name="createdAt" type="datetime" column="created_at" />
        <field name="updatedAt" type="datetime" column="updated_at"/>

    </entity>
</doctrine-mapping>
